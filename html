<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport"
        content="width=device-width, initial-scale=1.0">

    <title>College Event Portal</title>

    <link rel="stylesheet"
        href="style.css">

</head>

<body>

    <!-- Navigation Bar -->

    <nav>

        <ul>

            <li>
                <a href="#home">Home</a>
            </li>

            <li>
                <a href="#events">Events</a>
            </li>

            <li>
                <a href="#gallery">Gallery</a>
            </li>

            <li>
                <a href="#contact">Contact</a>
            </li>

        </ul>

    </nav>

    <!-- Home Section -->

    <section id="home">

        <h1>
            Welcome to College Event Portal
        </h1>

        <p>
            Participate in college activities
        </p>

    </section>

    <!-- Events Section -->

    <section id="events">

        <h2>
            Upcoming Events
        </h2>

        <ul>

            <li>
                Dance Competition
            </li>

            <li>
                Music Show
            </li>

            <li>
                Coding Contest
            </li>

            <li>
                Sports Day
            </li>

        </ul>

    </section>

    <!-- Gallery Section -->

    <section id="gallery">

        <h2>
            Event Gallery
        </h2>

        <table border="1">

            <tr>

                <td>
                    <img src="dance.jpg"
                        width="200"
                        height="150">
                </td>

                <td>
                    <img src="music.jpg"
                        width="200"
                        height="150">
                </td>

                <td>
                    <img src="sports.jpg"
                        width="200"
                        height="150">
                </td>

            </tr>

            <tr>

                <td>
                    Dance
                </td>

                <td>
                    Music
                </td>

                <td>
                    Sports
                </td>

            </tr>

        </table>

    </section>

    <!-- Registration Form -->

    <section>

        <h2>
            Registration Form
        </h2>

        <form>

            <input type="text"
                placeholder="Enter Name">

            <br><br>

            <input type="email"
                placeholder="Enter Email">

            <br><br>

            <input type="date">

            <br><br>

            <select>

                <option>
                    Select Event
                </option>

                <option>
                    Dance
                </option>

                <option>
                    Music
                </option>

                <option>
                    Sports
                </option>

            </select>

            <br><br>

            <textarea
                placeholder="Enter Feedback">
            </textarea>

            <br><br>

            <button>
                Submit
            </button>

        </form>

    </section>

    <!-- Video Section -->

    <section>

        <h2>
            Event Video
        </h2>

        <video width="400"
            controls>

            <source src="event.mp4"
                type="video/mp4">

        </video>

    </section>

    <!-- Contact Section -->

    <footer id="contact">

        <h2>
            Contact Us
        </h2>

        <p>
            Email : college@gmail.com
        </p>

        <p>
            Phone : 9876543210
        </p>

    </footer>

</body>

</html>
